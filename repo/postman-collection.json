{
  "info": {
    "name": "JusticeOps API Sequential",
    "description": "Sequential Postman collection for JusticeOps. Run top-to-bottom manually; prerequisites are captured into collection variables automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "superAdminUsername", "value": "superadmin" },
    { "key": "adminUsername", "value": "admin1" },
    { "key": "lawyerUsername", "value": "lawyer1" },
    { "key": "clientUsername", "value": "client1" },
    { "key": "defaultPassword", "value": "SecurePass1!" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "02 - Server Time",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/time"
      }
    },
    {
      "name": "03 - Login Super Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{superAdminUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('superAdminUserId', r.user.id);",
              "pm.collectionVariables.set('superAdminOrgId', r.user.orgId);"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Auth Me (Super Admin)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "05 - List Organizations",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/organizations?page=1&limit=20"
      }
    },
    {
      "name": "06 - Create Organization",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('newOrgName', 'Postman Org ' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('newOrgId', r.organization.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{newOrgName}}\",\n  \"settings\": {\n    \"timezone\": \"UTC\",\n    \"source\": \"postman\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/organizations"
      }
    },
    {
      "name": "07 - Update Organization",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{newOrgName}} Updated\",\n  \"settings\": {\n    \"timezone\": \"UTC\",\n    \"updatedBy\": \"postman\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/organizations/{{newOrgId}}"
      }
    },
    {
      "name": "08 - List Users",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/users?orgId={{superAdminOrgId}}&page=1&limit=20"
      }
    },
    {
      "name": "09 - Create Temp User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('tempUsername', 'tmp_user_' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('tempUserId', r.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{tempUsername}}\",\n  \"password\": \"{{defaultPassword}}\",\n  \"role\": \"client\",\n  \"orgId\": \"{{superAdminOrgId}}\",\n  \"isSessionExempt\": false\n}"
        },
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "10 - Update Temp User",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isActive\": true\n}"
        },
        "url": "{{baseUrl}}/api/users/{{tempUserId}}"
      }
    },
    {
      "name": "11 - Login Lawyer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{lawyerUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('lawyerUserId', r.user.id);",
              "pm.collectionVariables.set('lawyerOrgId', r.user.orgId);"
            ]
          }
        }
      ]
    },
    {
      "name": "12 - List Lawyers",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/lawyers"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "if (r.data && r.data.length > 0) pm.collectionVariables.set('selectedLawyerId', r.data[0].id);",
              "if (!pm.collectionVariables.get('selectedLawyerId')) pm.collectionVariables.set('selectedLawyerId', pm.collectionVariables.get('lawyerUserId'));"
            ]
          }
        }
      ]
    },
    {
      "name": "13 - List Availability",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/availability?lawyerId={{selectedLawyerId}}"
      }
    },
    {
      "name": "14 - Create Availability",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dayOfWeek\": 1,\n  \"startTime\": \"09:00\",\n  \"endTime\": \"11:00\",\n  \"slotDurationMin\": 30\n}"
        },
        "url": "{{baseUrl}}/api/availability"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('availabilityId', r.slot.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "15 - Update Availability",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"startTime\": \"09:30\",\n  \"endTime\": \"11:30\",\n  \"isActive\": true\n}"
        },
        "url": "{{baseUrl}}/api/availability/{{availabilityId}}"
      }
    },
    {
      "name": "16 - Delete Availability",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/availability/{{availabilityId}}"
      }
    },
    {
      "name": "17 - Login Client",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{clientUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('clientUserId', r.user.id);",
              "pm.collectionVariables.set('clientOrgId', r.user.orgId);"
            ]
          }
        }
      ]
    },
    {
      "name": "18 - List Bookings",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/bookings?page=1&limit=20"
      }
    },
    {
      "name": "19 - Create Booking (Confirm + Complete Flow)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const plus3h = new Date(now.getTime() + 3 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('scheduledAt1', plus3h);",
              "pm.collectionVariables.set('idem1', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('booking1Id', r.booking.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lawyerId\": \"{{selectedLawyerId}}\",\n  \"type\": \"consultation\",\n  \"scheduledAt\": \"{{scheduledAt1}}\",\n  \"idempotencyKey\": \"{{idem1}}\"\n}"
        },
        "url": "{{baseUrl}}/api/bookings"
      }
    },
    {
      "name": "20 - Get Booking by Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/bookings/{{booking1Id}}"
      }
    },
    {
      "name": "21 - Create Booking (Cancel Flow)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const plus1h = new Date(now.getTime() + 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('scheduledAt2', plus1h);",
              "pm.collectionVariables.set('idem2', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('booking2Id', r.booking.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lawyerId\": \"{{selectedLawyerId}}\",\n  \"type\": \"consultation\",\n  \"scheduledAt\": \"{{scheduledAt2}}\",\n  \"idempotencyKey\": \"{{idem2}}\"\n}"
        },
        "url": "{{baseUrl}}/api/bookings"
      }
    },
    {
      "name": "22 - Create Booking (Reschedule Flow)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const plus5h = new Date(now.getTime() + 5 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('scheduledAt3', plus5h);",
              "pm.collectionVariables.set('idem3', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('booking3Id', r.booking.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lawyerId\": \"{{selectedLawyerId}}\",\n  \"type\": \"consultation\",\n  \"scheduledAt\": \"{{scheduledAt3}}\",\n  \"idempotencyKey\": \"{{idem3}}\"\n}"
        },
        "url": "{{baseUrl}}/api/bookings"
      }
    },
    {
      "name": "23 - Login Lawyer (for booking actions)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{lawyerUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "24 - Confirm Booking #1",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/bookings/{{booking1Id}}/confirm"
      }
    },
    {
      "name": "25 - Confirm Booking #2",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/bookings/{{booking2Id}}/confirm"
      }
    },
    {
      "name": "26 - Complete Booking #1",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/bookings/{{booking1Id}}/complete"
      }
    },
    {
      "name": "27 - Login Client (for review/cancel/reschedule)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{clientUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "28 - Cancel Booking #2",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Client no longer needs this slot\"\n}"
        },
        "url": "{{baseUrl}}/api/bookings/{{booking2Id}}/cancel"
      }
    },
    {
      "name": "29 - Reschedule Booking #3",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const plus8h = new Date(Date.now() + 8 * 60 * 60 * 1000).toISOString();",
              "pm.collectionVariables.set('rescheduleAt', plus8h);",
              "pm.collectionVariables.set('idemReschedule', pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "if (r.newBooking && r.newBooking.id) pm.collectionVariables.set('rescheduledBookingId', r.newBooking.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newScheduledAt\": \"{{rescheduleAt}}\",\n  \"idempotencyKey\": \"{{idemReschedule}}\"\n}"
        },
        "url": "{{baseUrl}}/api/bookings/{{booking3Id}}/reschedule"
      }
    },
    {
      "name": "30 - Create Review (Client -> Lawyer)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingId\": \"{{booking1Id}}\",\n  \"timeliness\": 5,\n  \"professionalism\": 5,\n  \"communication\": 5,\n  \"comment\": \"Excellent handling and communication\"\n}"
        },
        "url": "{{baseUrl}}/api/reviews"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('reviewFromClientId', r.review.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "31 - Login Lawyer (for reciprocal review + dispute)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{lawyerUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('lawyerUserId', r.user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "32 - Create Review (Lawyer -> Client)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingId\": \"{{booking1Id}}\",\n  \"timeliness\": 5,\n  \"professionalism\": 4,\n  \"communication\": 5,\n  \"comment\": \"Client was responsive and prepared\"\n}"
        },
        "url": "{{baseUrl}}/api/reviews"
      }
    },
    {
      "name": "33 - List Reviews by Booking",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/reviews?bookingId={{booking1Id}}"
      }
    },
    {
      "name": "34 - Create Dispute (Lawyer disputes client review)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reviewId\": \"{{reviewFromClientId}}\",\n  \"reason\": \"Requesting review correction due to material factual mismatch.\"\n}"
        },
        "url": "{{baseUrl}}/api/disputes"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('disputeId', r.dispute.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "35 - Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const r = pm.response.json();",
              "pm.collectionVariables.set('token', r.token);",
              "pm.collectionVariables.set('adminUserId', r.user.id);",
              "pm.collectionVariables.set('adminOrgId', r.user.orgId);"
            ]
          }
        }
      ]
    },
    {
      "name": "36 - List Disputes",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/disputes?page=1&limit=20"
      }
    },
    {
      "name": "37 - Resolve Dispute",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resolution\": \"upheld\",\n  \"notes\": \"Resolved through admin review from Postman workflow.\"\n}"
        },
        "url": "{{baseUrl}}/api/disputes/{{disputeId}}/resolve"
      }
    },
    {
      "name": "38 - Credit History (Admin views client)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/credit/{{clientUserId}}?page=1&limit=20"
      }
    },
    {
      "name": "39 - Login Client (notifications/credit)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{clientUsername}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
