{
  "name": "justiceops-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed": "knex seed:run --knexfile knexfile.ts",
    "test": "vitest run",
    "test:unit": "vitest run src/domain src/application",
    "test:integration": "cross-env REQUIRE_DB_TESTS=1 vitest run src/infrastructure src/api",
    "test:db": "cross-env REQUIRE_DB_TESTS=1 vitest run src/api/routes/real-db-integration.test.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.0.2",
    "@fastify/multipart": "^9.0.3",
    "bcrypt": "^5.1.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "json2csv": "^6.0.0-alpha.2",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/json2csv": "^5.0.7",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.0.4",
    "cross-env": "^10.1.0",
    "knex": "^3.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
